# ============================================
# GHETTO VPN - Environment Configuration
# ============================================

# Application
APP_NAME=GHETTO VPN
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ghetto_vpn
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ123456789
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook
TELEGRAM_WEBHOOK_PATH=/webhook
TELEGRAM_ADMIN_IDS=123456789,987654321

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password Hashing
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# CORS
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Payment Providers
# YooKassa (ЮKassa)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_WEBHOOK_SECRET=your_webhook_secret

# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Crypto Payments (optional)
CRYPTO_USDT_ADDRESS=
CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=

# VPN Protocols
# WireGuard
WIREGUARD_ENABLED=True
WIREGUARD_SUBNET=10.8.0.0/24
WIREGUARD_DNS=1.1.1.1,8.8.8.8

# VLESS Reality
VLESS_ENABLED=True

# Xray
XRAY_ENABLED=True

# sing-box
SINGBOX_ENABLED=True

# Outline
OUTLINE_ENABLED=False

# Subscription Plans (in days)
PLAN_TRIAL_DAYS=3
PLAN_MONTHLY_DAYS=30
PLAN_QUARTERLY_DAYS=90
PLAN_SEMI_ANNUAL_DAYS=180
PLAN_ANNUAL_DAYS=365

# Subscription Prices (in RUB)
PRICE_MONTHLY=299
PRICE_QUARTERLY=799
PRICE_SEMI_ANNUAL=1499
PRICE_ANNUAL=2499
PRICE_LIFETIME=9999

# Referral System
REFERRAL_REWARD_DAYS=7
REFERRAL_REWARD_ENABLED=True

# File Storage
UPLOAD_DIR=./uploads
QR_CODE_DIR=./uploads/qr_codes
MAX_UPLOAD_SIZE=5242880

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# Monitoring
# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# Logging
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=json

# Backup
BACKUP_ENABLED=True
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Email (optional for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ghettovpn.com

# Admin Panel
ADMIN_PANEL_URL=https://admin.yourdomain.com
ADMIN_SESSION_LIFETIME=86400

# Maintenance Mode
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=We are currently performing maintenance. Please check back soon.

# Feature Flags
FEATURE_CRYPTO_PAYMENTS=False
FEATURE_REFERRAL_SYSTEM=True
FEATURE_PROMO_CODES=True
FEATURE_TRIAL_SUBSCRIPTION=True
