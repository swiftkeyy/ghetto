# Environment Configuration

# ============================================================================
# CORE SETTINGS
# ============================================================================
ENVIRONMENT=production  # development, staging, production
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# TELEGRAM BOT
# ============================================================================
BOT_TOKEN=your-telegram-bot-token-from-botfather
BOT_WEBHOOK_URL=https://yourdomain.com/webhook
BOT_WEBHOOK_SECRET=your-webhook-secret-token
ADMIN_USER_IDS=123456789,987654321  # Comma-separated admin Telegram IDs

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ghettovpn
POSTGRES_USER=ghettovpn
POSTGRES_PASSWORD=change-this-secure-password

# SQLAlchemy
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================================================================
# REDIS
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ============================================================================
# JWT & SECURITY
# ============================================================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Argon2 Settings
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_PARALLELISM=4

# Rate Limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60  # seconds

# ============================================================================
# VPN CONFIGURATION
# ============================================================================

# WireGuard
WIREGUARD_ENABLED=true
WIREGUARD_PORT=51820
WIREGUARD_INTERFACE=wg0
WIREGUARD_DNS=1.1.1.1,1.0.0.1

# VLESS Reality
VLESS_ENABLED=true
VLESS_PORT=443
VLESS_FLOW=xtls-rprx-vision

# Xray
XRAY_ENABLED=true
XRAY_API_PORT=8080
XRAY_CONFIG_PATH=/etc/xray/config.json

# sing-box
SINGBOX_ENABLED=true
SINGBOX_API_PORT=9090
SINGBOX_CONFIG_PATH=/etc/sing-box/config.json

# Outline
OUTLINE_ENABLED=true
OUTLINE_API_URL=https://outline.yourdomain.com
OUTLINE_API_KEY=your-outline-api-key

# ============================================================================
# SSH VPS INTEGRATION (v2.0 - NEW!)
# ============================================================================
# SSH интеграция для автоматического управления ключами на VPS серверах
# Эти настройки хранятся в database (server.config), но можно задать глобальные дефолты

# SSH Connection Settings
SSH_DEFAULT_PORT=22
SSH_DEFAULT_USER=root
SSH_CONNECTION_TIMEOUT=30  # seconds
SSH_COMMAND_TIMEOUT=60     # seconds

# SSH Key Management
# Рекомендуется использовать SSH ключи вместо паролей
# Путь к приватному ключу для подключения к VPS (опционально)
SSH_PRIVATE_KEY_PATH=/app/secrets/vps_ssh_key

# Auto Sync Settings
VPS_AUTO_SYNC_ENABLED=true
VPS_SYNC_INTERVAL=3600  # seconds (1 hour)
VPS_HEALTH_CHECK_INTERVAL=300  # seconds (5 minutes)

# WireGuard SSH Management
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
WG_INTERFACE=wg0
WG_IP_RANGE_START=10.0.0.2
WG_IP_RANGE_END=10.0.0.254

# Xray SSH Management
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_SERVICE_NAME=xray

# Monitoring Settings
MONITOR_CPU_THRESHOLD=80  # Alert if CPU > 80%
MONITOR_RAM_THRESHOLD=85  # Alert if RAM > 85%
MONITOR_DISK_THRESHOLD=90  # Alert if Disk > 90%

# ============================================================================
# PAYMENT PROVIDERS
# ============================================================================

# Stripe
STRIPE_ENABLED=true
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CryptoCloud / CryptoBot
CRYPTO_ENABLED=true
CRYPTO_API_KEY=your-crypto-api-key
CRYPTO_SHOP_ID=your-shop-id

# YooKassa (for Russia/CIS)
YOOKASSA_ENABLED=true
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Telegram Payments (Stars)
TELEGRAM_PAYMENT_TOKEN=your-payment-provider-token

# ============================================================================
# SUBSCRIPTION PLANS (USD)
# ============================================================================
PLAN_1_MONTH_PRICE=9.99
PLAN_3_MONTHS_PRICE=24.99
PLAN_6_MONTHS_PRICE=44.99
PLAN_12_MONTHS_PRICE=79.99
PLAN_LIFETIME_PRICE=299.99

# Trial Settings
TRIAL_ENABLED=true
TRIAL_DAYS=3
TRIAL_BANDWIDTH_GB=10

# ============================================================================
# REFERRAL SYSTEM
# ============================================================================
REFERRAL_ENABLED=true
REFERRAL_REWARD_DAYS=7  # Free days for referrer
REFERRAL_DISCOUNT_PERCENT=10  # Discount for referred user
REFERRAL_MIN_PAYOUT=10.00  # USD

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ghettovpn.com

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Sentry
SENTRY_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=${ENVIRONMENT}
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9091

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json, text

# ============================================================================
# ADMIN PANEL (v2.0 - UPDATED!)
# ============================================================================
# В v2.0 админ-панель полностью в Telegram боте!
# Веб-панель (Next.js) опциональна, можно не деплоить

# Telegram Admin Settings
TELEGRAM_ADMIN_ENABLED=true  # Админка в боте (основная)
TELEGRAM_ADMIN_NOTIFICATIONS=true  # Уведомления админам

# Web Admin Panel (опционально, для расширенной аналитики)
WEB_ADMIN_ENABLED=false  # Можно отключить, если не нужна веб-версия
ADMIN_PANEL_URL=https://admin.yourdomain.com
ADMIN_SESSION_SECRET=your-nextauth-secret-change-this
NEXTAUTH_URL=${ADMIN_PANEL_URL}
NEXTAUTH_SECRET=${ADMIN_SESSION_SECRET}

# ============================================================================
# SERVER LOCATIONS
# ============================================================================
# Format: CODE|Country|City|IP|Port|Protocol
# Example: US-NY|United States|New York|1.2.3.4|51820|wireguard

DEFAULT_SERVERS=\
US-NY|United States|New York|1.2.3.4|51820|wireguard,\
UK-LN|United Kingdom|London|5.6.7.8|51820|wireguard,\
DE-FR|Germany|Frankfurt|9.10.11.12|51820|wireguard,\
SG-SG|Singapore|Singapore|13.14.15.16|51820|wireguard,\
JP-TK|Japan|Tokyo|17.18.19.20|51820|wireguard

# ============================================================================
# CDN & ASSETS
# ============================================================================
CDN_ENABLED=false
CDN_URL=https://cdn.yourdomain.com
ASSETS_PATH=/app/assets

# ============================================================================
# BACKUP
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=ghettovpn-backups
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=your-s3-access-key
BACKUP_S3_SECRET_KEY=your-s3-secret-key

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_WEB_APP=true
FEATURE_ANDROID_TV=true
FEATURE_MULTI_DEVICE=true
FEATURE_BANDWIDTH_TRACKING=true
FEATURE_ANALYTICS=true
FEATURE_PROMO_CODES=true
FEATURE_REWARDS=true

# ============================================================================
# LOCALIZATION
# ============================================================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ru
TIMEZONE=UTC

# ============================================================================
# ADVANCED
# ============================================================================
MAX_DEVICES_PER_USER=5
MAX_SIMULTANEOUS_CONNECTIONS=3
BANDWIDTH_CHECK_INTERVAL=300  # seconds
SERVER_HEALTH_CHECK_INTERVAL=60  # seconds
CONFIG_CACHE_TTL=3600  # seconds
